---
// 核心：告诉Astro这个页面动态渲染，不静态生成
export const prerender = false;
// 适配Vercel边缘运行时
export const runtime = 'edge';

// 改成你自己的博客域名，不要加https://和末尾斜杠
const YOUR_BLOG_DOMAIN = 'blog.legspcpd.indevs.in';
// GitHub目标地址，不用改
const GITHUB_BASE = 'https://github.com';

// 1. 获取访问的路径
const pathSegments = Astro.params.path;
const fullPath = Array.isArray(pathSegments) ? pathSegments.join('/') : pathSegments || '';

// 2. 构建要请求的GitHub链接
const targetUrl = new URL(`/${fullPath}`, GITHUB_BASE);
targetUrl.search = Astro.url.search;

try {
  // 3. 转发请求到GitHub
  const githubResponse = await fetch(targetUrl.toString(), {
    method: Astro.request.method,
    headers: {
      'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
      'Accept': Astro.request.headers.get('accept') || 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
      'Accept-Language': Astro.request.headers.get('accept-language') || 'zh-CN,zh;q=0.9,en;q=0.8',
    },
    redirect: 'follow',
  });

  // 4. 处理页面内容，替换链接，保证点击后还在你的域名下
  let pageContent = await githubResponse.text();
  pageContent = pageContent.replaceAll('https://github.com', `https://${YOUR_BLOG_DOMAIN}/gh`);
  pageContent = pageContent.replaceAll('https://raw.githubusercontent.com', `https://${YOUR_BLOG_DOMAIN}/gh/raw`);

  // 5. 设置响应状态和头
  Astro.response.status = githubResponse.status;
  Astro.response.headers.set('Content-Type', githubResponse.headers.get('content-type') || 'text/html; charset=utf-8');
  Astro.response.headers.set('Cache-Control', 'public, max-age=1800');
---

<html set:html={pageContent}></html>