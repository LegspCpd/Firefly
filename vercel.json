{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": "astro",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    // 保留Yandex验证
    {
      "source": "/yandex_8100d571090b9d7d.html",
      "destination": "/yandex_8100d571090b9d7d"
    },
    // 核心：把 /gh/* 全部转发给 Vercel 原生函数
    {
      "source": "/gh/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/gh",
      "destination": "/api/"
    }
  ]
}